{
  "name": "codex_plus",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "package:desktop:deb": "node scripts/package-desktop-deb.mjs",
    "package:desktop:mac": "node scripts/package-desktop-mac.mjs",
    "deploy:relay": "node scripts/deploy-relay.mjs",
    "install:mobile:android": "node scripts/install-mobile-android.mjs",
    "dev:mobile": "npm run dev -w @codep/mobile -- --port 5175",
    "dev:mobile:lan": "npm run dev:mobile",
    "dev:desktop": "npm run dev:vite -w @codep/desktop -- --port 5174",
    "dev:relay": "cd services/relay && go run . -addr 0.0.0.0:8909",
    "probe:adapter": "npm --workspace @codep/codex-adapter run probe --"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
